34\langfenp1034\f2\cf3\ul Salm}}}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=19119002&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul o cap\u237?tulo 119 vers\u237?culo 2}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2  dice: \u8220?Felices los que hacen caso de sus recordatorios, los que lo buscan con todo el coraz\u243?n\u8221?. Y Jes\u250?s tambi\u233?n dijo: \u8220?\u161?Felices los que oyen la palabra de Dios y la ponen en pr\u225?ctica!\u8221? (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=42011028&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Lucas cap\u237?tulo 11 vers\u237?culo 28}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). Los siervos de Jehov\u225? somos felices porque leemos la Palabra de Dios con regularidad y nos esforzamos por poner en pr\u225?ctica lo que aprendemos (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=59001022-59001025&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Santiago cap\u237?tulo 1 vers\u237?culos 22 a 25}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). As\u237? agradamos a Jehov\u225? (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=21012013&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Eclesiast\u233?s cap\u237?tulo 12 vers\u237?culo 13}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). Por otro lado, seguir los consejos de la Palabra de Dios nos ayuda a llevarnos mejor con los miembros de nuestra familia y a ser mejores amigos de los hermanos de la congregaci\u243?n. Adem\u225?s, nos ahorramos muchos de los problemas que sufren quienes no\u160?obedecen las normas de Jehov\u225?. Es como dijo el rey David en una canci\u243?n despu\u233?s de mencionar la ley, las \u243?rdenes y las sentencias de Jehov\u225?: \u8220?Para quien las obedece hay una gran recompensa\u8221? (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=19019007-19019011&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Salmo cap\u237?tulo 19 vers\u237?culos 7 a 11}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). }{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i La Atalaya, septiembre de 2024 p\u225?gina }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 2}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2  }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 p\u225?rrafos}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2  }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 1 a 3\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\s3\qc {\rtlch\fcs1\alang1034\af1\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf2\b Martes 6 de enero\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\ql\fi576 {\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i Sana a los que tienen el coraz\u243?n destrozado y venda sus heridas (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=19147003&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i\ul Salmo cap\u237?tulo 147 vers\u237?culo 3}}}{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i ).\par}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 Jehov\u225? est\u225? muy pendiente de todo lo que nos pasa. Conoce bien nuestras alegr\u237?as y nuestras penas (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=19037018&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Salmo cap\u237?tulo 37 vers\u237?culo 18}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). Cuando ve que nos esforzamos al m\u225?ximo por servirle incluso en los momentos de angustia, se siente muy orgulloso de nosotros. Pero eso no\u160?es todo; desea apoyarnos y consolarnos. Hablando de \u8220?los que tienen el coraz\u243?n destrozado\u8221?, }{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=19147003&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf3\ul Salm}}}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=19147003&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul o cap\u237?tulo 147 vers\u237?culo 3}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2  dice que Jehov\u225? \u8220?venda sus heridas\u8221?. Este texto describe c\u243?mo \u233?l cuida con ternura a quienes est\u225?n heridos en sentido emocional. \u191?Qu\u233? tenemos que hacer para beneficiarnos de todos los cuidados que nos da? Pongamos un ejemplo. Si una persona tiene una herida, puede acudir a un buen m\u233?dico, pero para curarse tendr\u225? que seguir al pie de la letra todas sus instrucciones. Pues bien, por medio de su Palabra, Jehov\u225? les habla a quienes tienen una herida emocional y les da consejos con mucho amor. }{\rtlch\fcs1\alang1034\af2\ai\l