r?wtlocale=S&prefer=lang&bible=43017026&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf3\i\ul Jua}}}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=43017026&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i\ul n cap\u237?tulo 17 vers\u237?culo 26}}}{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i ).\par}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 Llevarles la verdad del Reino de Dios a las personas es un privilegio inmenso. De hecho, no\u160?todo el mundo puede hacerlo. Por ejemplo, cuando Jes\u250?s estuvo en la Tierra, no\u160?permiti\u243? que los demonios dieran testimonio sobre \u233?l (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=42004041&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Lucas cap\u237?tulo 4 vers\u237?culo 41}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). En nuestros tiempos, para que una persona pueda salir a predicar con los testigos de Jehov\u225?, primero tiene que llenar unos requisitos. \u191?C\u243?mo demostramos que valoramos el privilegio que tenemos de predicar? Aprovechando toda oportunidad para dar testimonio. Al igual que Jes\u250?s, tenemos la meta de plantar y regar las semillas de la verdad en los corazones de las personas (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=40013003-40013023&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Mateo cap\u237?tulo 13 vers\u237?culos 3,}}}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=40013003-40013023&pub=nwtsty" }}{\fldrslt{\cs5\rt