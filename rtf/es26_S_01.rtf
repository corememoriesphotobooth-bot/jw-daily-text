nder?wtlocale=S&prefer=lang&bible=05007001-05007003&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Deuteronomio cap\u237?tulo 7 vers\u237?culos 1 a 3}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ; }{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=23037036-23037037&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Isa\u237?as cap\u237?tulo 37 vers\u237?culos 36,}}}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=23037036-23037037&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf3\ul 37}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). En estos casos, la Biblia no\u160?nos da suficiente informaci\u243?n para afirmar que Jehov\u225? destruy\u243? para siempre a todas esas personas y que por tanto no\u160?van a resucitar. Aunque sabemos que Jehov\u225? destruy\u243? a estos grupos de personas como conjunto, no\u160?sabemos c\u243?mo ve\u237?a a cada una de esas personas ni\u160?tampoco si tuvieron la oportunidad de aprender sobre \u233?l y arrepentirse. }{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i La Atalaya, mayo de 2024 p\u225?gina }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 3}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2  }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 p\u225?rrafos}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2  }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 5 a 7\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\s3\qc {\rtlch\fcs1\alang1034\af1\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf2\b Jueves 8 de enero\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\ql\fi576 {\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i Sigue venciendo el mal con el bien (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=45012021&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i\ul Romanos cap\u237?tulo 12 vers\u237?culo 21}}}{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i ).\par}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 Jes\u250?s puso una comparaci\u243?n de una viuda que le ped\u237?a una y otra vez a un juez que se le hiciera justicia. Seguro que los disc\u237?pulos pod\u237?an ponerse en el lugar de la mujer porque en aquella \u233?poca muchas personas sufr\u237?an injusticias (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=42018001-42018005&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Lucas cap\u237?tulo 18 vers\u237?culos 1 a 5}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). Nosotros tambi\u233?n podemos entender c\u243?mo se debi\u243? sentir aquella viuda porque a todos se nos ha tratado injustamente alguna vez. No\u160?nos sorprende que nos traten as\u237? porque el prejuicio, la desigualdad y la opresi\u243?n son el pan de cada d\u237?a en este mundo (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=21005008&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Eclesiast\u233?s cap\u237?tulo 5 vers\u237?culo 8}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). Lo que quiz\u225?s s\u237? nos sorprenda es que un hermano o una hermana nos trate mal. Claro, ellos no\u160?son como los que se oponen a la verdad. Pero, como son imperfectos, puede que a veces sean injustos con nosotros. Podemos aprender mucho de c\u243?mo reaccion\u243? Jes\u250?s cuando fue v\u237?ctima de injusticias por parte de malvados enemigos. Si nos esforzamos por ser pacientes con nuestros enemigos cuando nos tratan injustamente, \u191?c\u243?mo no\u160?lo vamos a hacer con nuestros hermanos? }{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i La Atalaya, noviembre de 2024 p\u225?gina }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 2}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2  }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 p\u225?rrafos}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2  1,\u160?2\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\s3\qc {\rtlch\fcs1\alang1034\af1\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf2\b Viernes 9 de enero\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\ql\fi576 {\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i \u191?D\u243?nde compraremos pan para que esta gente coma? (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=43006005&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf3\i\ul Jua}}}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=43006005&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i\ul n cap\u237?tulo 6 vers\u237?culo 5}}}{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i ).\par}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 El pan era un alimento b\u225?sico en tiempos b\u237?blicos (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=01014018&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul G\u233?nesis cap\u237?tulo 14 vers\u237?culo 18}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ; }{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=42004004&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Lucas cap\u237?tulo 4 vers\u237?culo 4}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). Era tan importante que la Biblia a veces lo usa para referirse a la comida en general (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=40006011&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Mateo cap\u237?tulo 6 vers\u237?culo 11}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ; }{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=44020007&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Hechos cap\u237?tulo 20 vers\u237?culo 7}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 , nota de estudio). El pan fue tambi\u233?n un elemento central de dos milagros de Jes\u250?s muy conocidos (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=40016009-40016010&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Mateo cap\u237?tulo 16 vers\u237?culos 9,}}}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=40016009-40016010&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf3\ul 10}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). Uno de esos relatos se encuentra en el cap\u237?tulo 6 de Jua}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 n}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 . Los ap\u243?stoles hab\u237?an terminado una gira de predicaci\u243?n. Jes\u250?s cruz\u243? con ellos el mar de Galilea en barca y los llev\u243? a un lugar retirado cerca de la ciudad de Betsaida para que pudieran descansar (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=41006007-41006032&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Marcos cap\u237?tulo 6 vers\u237?culos 7,30 a 32}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ; }{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=42009010&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Lucas cap\u237?tulo 9 vers\u237?culo 10}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). Pero enseguida se vieron rodeados por miles de personas que vinieron a ver a Jes\u250?s. Y \u233?l no\u160?las ignor\u243?. Bondadosamente, dedic\u243? tiempo a hablarles del Reino y a curar a los enfermos. Como se estaba haciendo tarde, los disc\u237?pulos se preguntaban c\u243?mo har\u237?a toda esa gente para conseguir algo de comer. Algunos quiz\u225?s llevaban unas pocas provisiones, pero la mayor\u237?a tendr\u237?a que ir a las aldeas y comprar comida (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=40014015&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Mateo cap\u237?tulo 14 vers\u237?culo 15}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). }{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i La Atalaya, diciembre de 2024 p\u225?gina }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 2}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2  }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 p\u225?rrafos}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2  1,\u160?2\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\s3\qc {\rtlch\fcs1\alang1034\af1\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf2\b S\u225?bado 10 de enero\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\ql\fi576 {\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i El regalo que Dios da es la vida eterna por Cristo Jes\u250?s nuestro Se\u241?or (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=45006023&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i\ul Romanos cap\u237?tulo 6 vers\u237?culo 23}}}{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i ).\par}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 Nuestros primeros padres, Ad\u225?n y Eva, eran perfectos y viv\u237?an en un hermoso para\u237?so (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=01001027&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul G\u233?nesis cap\u237?tulo 1 vers\u237?culo 27}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ; }{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=01002007-01002009&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Cap\u237?tulo 2 vers\u237?culo 7 a 9}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). Podr\u237?an haber disfrutado para siempre de una vida feliz y pr\u243?spera. Pero entonces todo cambi\u243?. Perdieron su bello hogar y la posibilidad de vivir para siempre. \u191?Qu\u233? herencia les dejaron a sus futuros hijos? La Biblia nos dice: \u8220?Por medio de un solo hombre [Ad\u225?n], el pecado entr\u243? en el mundo y por medio del pecado entr\u243? la muerte, y as\u237? fue como la muerte se extendi\u243? a todos los hombres, porque todos hab\u237?an pecado\u8221? (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=45005012&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Romanos cap\u237?tulo 5 vers\u237?culo 12}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). La herencia que nos dej\u243? Ad\u225?n es el pecado, que nos lleva a la muerte. El pecado heredado es como una deuda enorme que ninguno de nosotros puede pagar (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=19049008&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Salmo cap\u237?tulo 49 vers\u237?culo 8}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). Jes\u250?s compar\u243? los pecados a \u8220?deudas\u8221? (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=40006012&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe10