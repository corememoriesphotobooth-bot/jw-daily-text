h\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 . Esta profec\u237?a nos ense\u241?a que Dios tiene muchas ganas de que sus siervos fieles disfruten de su amistad. Jehov\u225? prometi\u243? hacer \u8220?con ellos un pacto de paz\u8221?. Estas palabras se cumplir\u237?an cuando los que tienen la esperanza de vivir en el cielo y los que tienen la esperanza de vivir en la Tierra estuvieran unidos como \u8220?un solo reba\u241?o\u8221? dentro de su tienda simb\u243?lica (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=43010016&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf3\ul Jua}}}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=43010016&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul n cap\u237?tulo 10 vers\u237?culo 16}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). Esa profec\u237?a se est\u225? cumpliendo hoy en d\u237?a. }{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i La Atalaya, junio de 2024 p\u225?gina }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 2}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2  }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 p\u225?rrafos}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2  2,\u160?4; 3 }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 p\u225?rrafo}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2  5\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\s3\qc {\rtlch\fcs1\alang1034\af1\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf2\b Domingo 8 de febrero\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\ql\fi576 {\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i Por medio de nuestro Dios cobramos valor (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=52002002&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i\ul Primera a los Tesalonicenses cap\u237?tulo 2 vers\u237?culo 2}}}{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i ).\par}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 Los siervos de Jehov\u225? apoyamos de todo coraz\u243?n el Reino de Dios, pero a menudo eso requiere valor (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=40006033&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Mateo cap\u237?tulo 6 vers\u237?culo 33}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). Por ejemplo, en este mundo malo necesitamos valor para obedecer las normas de Jehov\u225? y para predicar las buenas noticias del Reino. Mantenernos neutrales tampoco es f\u225?cil en un sistema que est\u225? cada vez m\u225?s dividido (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=43018036&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf3\ul Jua}}}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=43018036&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul n cap\u237?tulo 18 vers\u237?culo 36}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). Y muchos testigos de Jehov\u225? han tenido que afrontar problemas econ\u243?micos, maltrato f\u237?sico o incluso la prisi\u243?n por negarse a participar en actividades pol\u237?ticas o militares. Analizar el ejemplo de siervos de Jehov\u225? que han apoyado su Reino nos da fuerzas y valor. Nuestro Rey, Jesucristo, no\u160?quiso tener nada que ver con el sistema pol\u237?tico de Satan\u225?s (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=40004008-40004011&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Mateo cap\u237?tulo 4 vers\u237?culos 8 a 11}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ; }{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=43006014-43006015&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf3\ul Jua}}}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=43006014-43006015&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul n cap\u237?tulo 6 vers\u237?culos 14,}}}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=43006014-43006015&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf3\ul 15}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). Siempre confi\u243? en Jehov\u225? para conseguir fuerzas. }{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i La Atalaya, julio de 2024 p\u225?gina }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 3}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2  }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 p\u225?rrafo}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2  4; 4 }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 p\u225?rrafo}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2  7\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\s3\qc {\rtlch\fcs1\alang1034\af1\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf2\b Lunes 9 de febrero\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\ql\fi576 {\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i Ella agarr\u243? de su fruto y empez\u243? a comer. Despu\u233?s, estando ya con su esposo, le dio a \u233?l del fruto y \u233?l se puso a comerlo (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=01003006&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i\ul G\u233?nesis cap\u237?tulo 3 vers\u237?culo 6}}}{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i ).\par}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 Todo este relato es muy triste, pero Jehov\u225? lo ha puesto en la Biblia para que entendamos algo muy importante: por qu\u233? odia tanto el pecado. El pecado nos aleja de nuestro Padre y nos lleva a la muerte (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=23059002&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Isa\u237?as cap\u237?tulo 59 vers\u237?culo 2}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). Esa es justo la raz\u243?n por la que aquel \u225?ngel rebelde \u8212?Satan\u225?s\u8212? ama el pecado, por la que tent\u243? a Ad\u225?n y Eva, y por la que nos sigue tentando a nosotros. Tal vez pens\u243? que en el jard\u237?n de Ed\u233?n hab\u237?a logrado una gran victoria. Pero no\u160?entend\u237?a lo profundo que es el amor de Jehov\u225?. Dios nunca cambi\u243? el prop\u243?sito que ten\u237?a para los descendientes de Ad\u225?n y Eva. \u201?l ama a los seres humanos y por eso de inmediato les ofreci\u243? una esperanza a todos ellos (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=45008020-45008021&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Romanos cap\u237?tulo 8 vers\u237?culos 20,}}}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=45008020-45008021&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf3\ul 21}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). Sab\u237?a que algunos decidir\u237?an amarlo y buscar\u237?an su ayuda para luchar contra el pecado. Y Jehov\u225?, como Creador y buen Padre que es, har\u237?a posible que se acercaran a \u233?l y vencieran al pecado y la muerte. }{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i La Atalaya, agosto de 2024 p\u225?gina }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 3}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2  }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 p\u225?rrafos}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2  3,\u160?4\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\s3\qc {\rtlch\fcs1\alang1034\af1\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf2\b Martes 10 de febrero\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\ql\fi576 {\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i Aseg\u250?rense de qu\u233? cosas son las m\u225?s importantes (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=50001010&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i\ul Filipenses cap\u237?tulo 1 vers\u237?culo 10}}}{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i ).\par}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 La mayor\u237?a de los siervos de Jehov\u225? somos personas muy ocupadas. Tenemos que trabajar para mantenernos a nosotros y a nuestra familia (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=54005008&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Primera a Timoteo cap\u237?tulo 5 vers\u237?culo 8}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). Muchos hermanos cuidan a familiares que est\u225?n enfermos o son mayores. Y todos tenemos que sacar tiempo para cuidar nuestra propia salud. Tambi\u233?n est\u225?n las responsabilidades de la congregaci\u243?n. Una muy importante es participar de lleno en la predicaci\u243?n. Leer la Biblia es una de las cosas \u8220?m\u225?s importantes\u8221? para los cristianos, as\u237? que debemos asegurarnos de hacerlo. El libro de los Salmos comienza diciendo que el hombre feliz \u8220?disfruta con la ley de Jehov\u225?; d\u237?a y noche lee su ley y medita en ella\u8221? (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=19001001-19001002&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Salmo cap\u237?tulo 1 vers\u237?culos 1,}}}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=19001001-19001002&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf3\ul 2}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). Est\u225? claro que hay que apartar tiempo para leerla. Ahora bien, \u191?cu\u225?l es el mejor momento del d\u237?a para leer la Biblia? Depende de cada uno. Pero la cuesti\u243?n es que escojamos un momento que nos permita ser constantes. }{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i La Atalaya, septiembre de 2024 p\u225?gina }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 3}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2  }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 p\u225?rrafos}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2  5,\u160?6\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\s3\qc {\rtlch\fcs1\alang1034\af1\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf2\b Mi\u233?rcoles 11 de febrero\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\ql\fi576 {\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i Cada uno llevar\u225? su propia carga de responsabilidad (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=48006005&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i\ul G\u225?latas cap\u237?tulo 6 vers\u237?culo 5}}}{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i ).\par}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 \u191?Necesitan los cristianos maduros que en ocasiones los ayuden? S\u237?. Hay veces en las que quiz\u225?s necesiten pedir ayuda. Un cristiano inmaduro tal vez espere que los dem\u225?s decidan por \u233?l o le digan qu\u233? hacer, mientras que un cristiano maduro aprovecha la sabidur\u237?a y los consejos de los hermanos con m\u225?s experiencia pero sabe que tiene que llevar \u8220?su propia carga de responsabilidad\u8221?. As\u237? como no\u160?todas las personas adultas tienen las mismas caracter\u237?sticas f\u237?sicas, no\u160?todos los cristianos maduros tienen las mismas cualidades espirituales. Por ejemplo, algunos destacan por su sabidur\u237?a, otros por su valor, otros por su generosidad y otros por su empat\u237?a. Adem\u225?s, es posible que dos cristianos maduros lleguen a conclusiones distintas sobre un mismo asunto \u8212?en especial en temas de conciencia\u8212? y que las dos conclusiones sean v\u225?lidas desde el punto de vista b\u237?blico. Por eso, ninguno criticar\u225? lo que decida el otro, sino que los dos se esforzar\u225?n por mantener la unidad (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=45014010&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Romanos cap\u237?tulo 14 vers\u237?culo 10}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ; }{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=46001010&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Primera a los Corintios cap\u237?tulo 1 vers\u237?culo 10}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). }{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i La Atalaya, abril de 2024 p\u225?gina }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 4}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2  }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 p\u225?rrafos}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2  7,\u160?8\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\s3\qc {\rtlch\fcs1\alang1034\af1\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf2\b Jueves 12 de febrero\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\ql\fi576 {\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i Cuando las preocupaciones me abrumaban, t\u250? me consolabas y me tranquilizabas (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=19094019&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i\ul Salmo cap\u237?tulo 94 vers\u237?culo 19}}}{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i ).\par}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 \u191?Qu\u233? puedes hacer si sientes que no\u160?vales nada? Lee textos de la Biblia que te confirmen que Jehov\u225? te valora, y medita en ellos. Si no\u160?alcanzaste una meta o no\u160?puedes hacer tanto como otros, no\u160?te desanimes ni\u160?seas demasiado duro contigo mismo. Jehov\u225? es razonable y no\u160?espera de ti m\u225?s de lo que puedes hacer (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=19103013-19103014&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Salmo cap\u237?tulo 103 vers\u237?culos 13,}}}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=19103013-19103014&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf3\ul 14}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). Si sufriste maltratos o abusos, no\u160?te culpes por lo que otra persona te hizo. No\u160?fue culpa tuya ni\u160?hiciste nada para merecerlo. Recuerda que Dios les pedir\u225? cuentas a los que hacen cosas malas, no\u160?a las v\u237?ctimas (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=60003012&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Primera de Pedro cap\u237?tulo 3 vers\u237?culo 12}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). Aunque a veces te cueste creerlo, Jehov\u225? puede usarte para ayudar a otros. Te ha dado el honor de colaborar con \u233?l en la predicaci\u243?n (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=46003009&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Primera a los Corintios cap\u237?tulo 3 vers\u237?culo 9}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). Es muy probable que debido a tus vivencias del pasado ahora seas m\u225?s emp\u225?tico y comprendas mejor los sentimientos de otras personas. Puedes hacerles mucho bien. }{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i La Atalaya, octubre de 2024 p\u225?ginas }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 7,\u160?8}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2  }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 p\u225?rrafos}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2  6,\u160?7\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\s3\qc {\rtlch\fcs1\alang1034\af1\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf2\b Viernes 13 de febrero\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\ql\fi576 {\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i \u191?No se va a encargar Dios de que se les haga justicia a los escogidos suyos que d\u237?a y noche le suplican ayuda, mientras \u233?l es paciente con ellos? Les digo que \u233?l se encargar\u225? de que se les haga justicia r\u225?pidamente (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=42018007-42018008&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i\ul Lucas cap\u237?tulo 18 vers\u237?culos 7,}}}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=42018007-42018008&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf3\i\ul 8}}}{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i ).\par}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 A Jehov\u225? le importa much\u237?simo c\u243?mo nos tratan. \u8220?Jehov\u225? ama la justicia\u8221? (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=19037028&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Salmo cap\u237?tulo 37 vers\u237?culo 28}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). Jes\u250?s dijo que Dios \u8220?se encargar\u225? de que se les haga justicia r\u225?pidamente\u8221? a sus siervos en el momento indicado. Y pronto eliminar\u225? todo el sufrimiento y no\u160?permitir\u225? que suframos injusticias nunca m\u225?s (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=19072001-19072002&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Salmo cap\u237?tulo 72 vers\u237?culos 1,}}}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=19072001-19072002&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf3\ul 2}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). Mientras esperamos a que llegue el momento en el que reine la justicia, Jehov\u225? nos ense\u241?a c\u243?mo reaccionar ante las injusticias (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=61003013&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Segunda de Pedro cap\u237?tulo 3 vers\u237?culo 13}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). Por ejemplo, nos muestra qu\u233? debemos hacer para no\u160?empeorar las cosas. Tambi\u233?n nos da un modelo perfecto a seguir: el de su Hijo. Y en la Biblia nos ofrece consejos muy \u250?tiles que podemos aplicar cuando se nos trata injustamente. }{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i La Atalaya, noviembre de 2024 p\u225?ginas }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 2,\u160?3}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2  }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 p\u225?rrafos}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2  3,\u160?4\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\s3\qc {\rtlch\fcs1\alang1034\af1\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf2\b S\u225?bado 14 de febrero\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\ql\fi576 {\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i Denles de comer (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=40014016&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i\ul Mateo cap\u237?tulo 14 vers\u237?culo 16}}}{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i ).\par}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 La petici\u243?n de Jes\u250?s a sus ap\u243?stoles de alimentar a la multitud era un gran problema porque hab\u237?a unos 5.000 hombres. Y, si se a\u241?aden las mujeres y los ni\u241?os, pueden haber sido unas 15.000 personas (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=40014021&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Mateo cap\u237?tulo 14 vers\u237?culo 21}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). Andr\u233?s dijo: \u8220?Aqu\u237? hay un ni\u241?o que tiene cinco panes de cebada y dos pescaditos. Pero \u191?qu\u233? es eso para tanta gente?\u8221? (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=43006009&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf3\ul Jua}}}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=43006009&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul n cap\u237?tulo 6 vers\u237?culo 9}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). El pan de cebada era com\u250?n y barato, y los pescaditos quiz\u225?s fueran secos y salados. En cualquier caso, esa cantidad no\u160?alcanzar\u237?a para alimentar a tanta gente. Como Jes\u250?s quer\u237?a ser hospitalario, le pidi\u243? a la multitud que se sentara por grupos en la hierba (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=41006039-41006040&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Marcos cap\u237?tulo 6 vers\u237?culos 39,}}}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=41006039-41006040&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf3\ul 40}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ; }{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=43006011-43006013&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf3\ul Jua}}}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=43006011-43006013&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul n cap\u237?tulo 6 vers\u237?culos 11 a 13}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). La Biblia dice que Jes\u250?s le dio gracias a su Padre por el pan y los pescaditos. Fue muy apropiado que lo hiciera, porque en realidad fue Dios el que proporcion\u243? la comida. Esto nos recuerda que debemos seguir el ejemplo de Jes\u250?s y orar antes de comer. Despu\u233?s, Jes\u250?s hizo que se distribuyera la comida, y la multitud comi\u243? hasta quedar satisfecha. }{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i La Atalaya, diciembre de 2024 p\u225?ginas }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 2,\u160?3}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2  }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 p\u225?rrafos}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2  3,\u160?4\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\s3\qc {\rtlch\fcs1\alang1034\af1\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf2\b Domingo 15 de febrero\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\ql\fi576 {\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i Alaben a Jehov\u225? su Dios (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=13029020&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i\ul Primero de las Cr\u243?nicas cap\u237?tulo 29 vers\u237?culo 20}}}{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i ).\par}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 Cuando Jes\u250?s estuvo en la Tierra, le dio gloria a su Padre de muchas maneras. Por ejemplo, siempre explicaba que sus milagros los hac\u237?a mediante el poder de Jehov\u225? (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=41005018-41005020&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Marcos cap\u237?tulo 5 vers\u237?culos 18 a 20}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). Tambi\u233?n le daba gloria por su forma de hablar de \u233?l y por la manera en que trataba a los dem\u225?s. En cierta ocasi\u243?n, Jes\u250?s estaba ense\u241?ando en una sinagoga y entre los presentes hab\u237?a una mujer que llevaba 18 a\u241?os pose\u237?da por un demonio. Por culpa de ese demonio, estaba muy encorvada y no\u160?se pod\u237?a enderezar. \u161?Qu\u233? situaci\u243?n tan terrible! Al darse cuenta de lo mucho que deb\u237?a de estar sufriendo, Jes\u250?s se compadeci\u243? de ella y le dijo con cari\u241?o: \u8220?Mujer, quedas libre de tu debilidad\u8221?. Luego, puso las manos sobre ella, y al instante ella se enderez\u243? y \u8220?comenz\u243? a darle gloria a Dios\u8221? (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=42013010-42013013&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Lucas cap\u237?tulo 13 vers\u237?culos 10 a 13}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). Aquella mujer que hab\u237?a recuperado la salud y la dignidad ten\u237?a buenos motivos para darle gloria a Jehov\u225?; y nosotros tambi\u233?n los tenemos. }{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i La Atalaya, enero de 2025 p\u225?ginas }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 2,\u160?3}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2  }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 p\u225?rrafos}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2  3,\u160?4\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\s3\qc {\rtlch\fcs1\alang1034\af1\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf2\b Lunes 16 de febrero\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\ql\fi576 {\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i Perd\u243?nanos nuestros pecados (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=42011004&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i\ul Lucas cap\u237?tulo 11 vers\u237?culo 4}}}{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i ).\par}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 Nosotros solos no\u160?podemos recuperar todo lo que Ad\u225?n y Eva perdieron (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=19049007-19049009&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Salmo cap\u237?tulo 49 vers\u237?culos 7 a 9}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). Sin ayuda, no\u160?tendr\u237?amos la esperanza de vivir para siempre ni\u160?de resucitar. Tendr\u237?amos el mismo final que los animales (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=21003019&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Eclesiast\u233?s cap\u237?tulo 3 vers\u237?culo 19}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ; }{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=61002012&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Segunda de Pedro cap\u237?tulo 2 vers\u237?culo 12}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). Jehov\u225?, nuestro Padre que nos quiere, nos ha dado un regalo que paga la deuda del pecado que hemos heredado de Ad\u225?n. Jes\u250?s explic\u243? en qu\u233? consiste ese regalo: \u8220?Dios am\u243? tanto al mundo que entreg\u243? a su Hijo unig\u233?nito para que nadie que demuestre tener fe en \u233?l sea destruido, sino que tenga vida eterna\u8221? (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=43003016&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf3\ul Jua}}}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=43003016&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul n cap\u237?tulo 3 vers\u237?culo 16}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). Ese regalo tambi\u233?n nos permite disfrutar de una buena relaci\u243?n con Jehov\u225?. Podemos beneficiarnos de ese maravilloso regalo y recibir el perd\u243?n de nuestros pecados. }{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i La Atalaya, febrero de 2025 p\u225?ginas }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 2,\u160?3}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2  }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 p\u225?rrafos}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2  }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 3 a 6\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\s3\qc {\rtlch\fcs1\alang1034\af1\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf2\b Martes 17 de febrero\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\ql\fi576 {\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i Saulo se levant\u243? y fue bautizado (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=44009018&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i\ul Hechos cap\u237?tulo 9 vers\u237?culo 18}}}{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i ).\par}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 \u191?Qu\u233? ayud\u243? a Saulo a bautizarse? Cuando Jes\u250?s le habl\u243? desde el cielo, una luz brillante dej\u243? ciego a Saulo (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=44009003-44009009&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Hechos cap\u237?tulo 9 vers\u237?culos 3 a 9}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). Durante tres d\u237?as no\u160?comi\u243? nada y seguro que estuvo meditando en lo que le hab\u237?a pasado. Se convenci\u243? de que Jes\u250?s era el Mes\u237?as y de que los cristianos eran la religi\u243?n verdadera. El ejemplo de Saulo nos ense\u241?a varias lecciones. \u201?l podr\u237?a haber dejado que el orgullo o el miedo le impidieran bautizarse. Pero no\u160?dej\u243? que nada lo frenara. Tom\u243? la decisi\u243?n de hacerse cristiano aunque sab\u237?a que ser\u237?a perseguido (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=44009015-44009016&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Hechos cap\u237?tulo 9 vers\u237?culos 15,}}}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=44009015-44009016&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf3\ul 16}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ; }{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=44020022-44020023&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Cap\u237?tulo 20 vers\u237?culo 2}}}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=44020022-44020023&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf3\ul 2,23}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). Despu\u233?s de su bautismo, sigui\u243? confiando en la ayuda de Jehov\u225? al enfrentarse a todo tipo de pruebas (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=47004007-47004010&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Segunda a los Corintios cap\u237?tulo 4 vers\u237?culos 7 a 10}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). Cuando usted se bautice como testigo de Jehov\u225?, puede que sufra pruebas o alg\u250?n tipo de oposici\u243?n, pero no\u160?estar\u225? solo. Jehov\u225? y Jes\u250?s siempre estar\u225?n a su lado para apoyarlo (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=50004013&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Filipenses cap\u237?tulo 4 vers\u237?culo 13}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). }{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i La Atalaya, marzo de 2025 p\u225?gina }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 4}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2  }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 p\u225?rrafos}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2  8,\u160?9\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\s3\qc {\rtlch\fcs1\alang1034\af1\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf2\b Mi\u233?rcoles 18 de febrero\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\ql\fi576 {\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i No corro sin una meta (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=46009026&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i\ul Primera a los Corintios cap\u237?tulo 9 vers\u237?culo 26}}}{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i ).\par}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 Leer la Biblia es una buena meta, pero si queremos sacarle el m\u225?ximo beneficio tenemos que hacer algo m\u225?s. Pensemos en el siguiente ejemplo. La lluvia es esencial para las plantas. Pero, si cae demasiada agua en poco tiempo, la tierra puede saturarse. En ese caso, m\u225?s lluvia no\u160?causa ning\u250?n beneficio. Es mejor que la lluvia caiga poco a poco, porque as\u237? la tierra tiene tiempo para absorberla y las plantas pueden crecer. De la misma manera, debemos evitar leer la Biblia con tanta prisa que no\u160?logremos absorber lo que leemos y luego recordarlo y aplicarlo (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=59001024&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Santiago cap\u237?tulo 1 vers\u237?culo 24}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). Supongamos que est\u225? leyendo la Biblia y nota que va a toda prisa. \u191?Qu\u233? puede hacer? Trate de ir m\u225?s despacio y leer a un ritmo que le permita meditar en lo que est\u225? leyendo o acaba de leer. Podr\u237?a prolongar el periodo de estudio para incluir tiempo para meditar. }{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i La Atalaya, septiembre de 2024 p\u225?ginas }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 4,\u160?5}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2  }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 p\u225?rrafos}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2  }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 7 a 9\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\s3\qc {\rtlch\fcs1\alang1034\af1\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf2\b Jueves 19 de febrero\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\ql\fi576 {\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i Sean obedientes y sumisos a los que los dirigen (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=58013017&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i\ul Hebreos cap\u237?tulo 13 vers\u237?culo 17}}}{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i ).\par}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 Los ancianos leen con mucha atenci\u243?n las instrucciones que reciben y luego las siguen lo mejor que pueden. Reciben instrucciones sobre c\u243?mo deben hacerse las asignaciones y las oraciones en la reuni\u243?n, pero tambi\u233?n sobre c\u243?mo deben cuidar a las ovejas de Cristo. Cuando los ancianos siguen todas las instrucciones que les da la organizaci\u243?n, los hermanos sienten que Jehov\u225? los quiere y los est\u225? cuidando. Cuando los ancianos nos den una instrucci\u243?n, lo mejor que podemos hacer es seguirla de buena gana. As\u237? les hacemos m\u225?s f\u225?cil cumplir con su responsabilidad. La Biblia nos dice que seamos obedientes y sumisos a los que nos dirigen (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=58013007-58013017&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Hebreos cap\u237?tulo 13 vers\u237?culos 7,}}}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=58013007-58013017&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf3\ul 17}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). Eso no\u160?siempre es f\u225?cil, porque los ancianos son imperfectos. Pero recordemos que, si en vez de centrarnos en sus cosas buenas nos obsesionamos con sus defectos, estar\u237?amos haciendo justo lo que quieren nuestros enemigos. \u191?Por qu\u233? decimos esto? Porque, si pensamos mal de los ancianos, podemos terminar desconfiando de la organizaci\u243?n de Dios. }{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i La Atalaya, abril de 2024 p\u225?gina }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 1}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 0 }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 p\u225?rrafos}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2  11,\u160?12\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\s3\qc {\rtlch\fcs1\alang1034\af1\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf2\b Viernes 20 de febrero\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\ql\fi576 {\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i \u201?l separar\u225? a las personas unas de otras (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=40025032&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i\ul Mateo cap\u237?tulo 25 vers\u237?culo 32}}}{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i ).\par}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 \u191?Qu\u233? pasar\u225? con todas las personas que mueran durante la gran tribulaci\u243?n? \u191?Ser\u225?n destruidas para siempre y por tanto no\u160?tendr\u225?n la oportunidad de resucitar? La Biblia deja claro que quienes no\u160?van a resucitar son las personas a las que Jehov\u225? y sus ej\u233?rcitos destruyan en el Armaged\u243?n por haberse opuesto abiertamente a \u233?l (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=53001006-53001010&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Segunda a los Tesalonicenses cap\u237?tulo 1 vers\u237?culos 6 a 10}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). Pero \u191?y qu\u233? decir de quienes mueran durante la gran tribulaci\u243?n debido a causas naturales, accidentes o a manos de otras personas? (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=21009011&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Eclesiast\u233?s cap\u237?tulo 9 vers\u237?culo 11}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ; }{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=38014013&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Zacar\u237?as cap\u237?tulo 14 vers\u237?culo 13}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). \u191?Puede ser que algunos de ellos est\u233?n entre los \u8220?injustos\u8221? que resucitar\u225?n en el nuevo mundo? (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=44024015&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Hechos cap\u237?tulo 24 vers\u237?culo 15}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). La verdad, no\u160?lo sabemos. Pero hay varias cosas que s\u237? sabemos sobre los acontecimientos futuros. Por ejemplo, sabemos que en el Armaged\u243?n las personas ser\u225?n tratadas de acuerdo con c\u243?mo hayan tratado a los hermanos de Cristo (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=40025040&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Mateo cap\u237?tulo 25 vers\u237?culo 40}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). Y quienes hayan dado su apoyo a los ungidos y a Cristo ser\u225?n tratados como ovejas (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=66012017&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Apocalipsis cap\u237?tulo 12 vers\u237?culo 17}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). }{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i La Atalaya, mayo de 2024 p\u225?ginas }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 10,\u160?1}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 1 }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 p\u225?rrafos}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2  }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 9 a 11\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\s3\qc {\rtlch\fcs1\alang1034\af1\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf2\b S\u225?bado 21 de febrero\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\ql\fi576 {\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i \u161?Jehov\u225? vive! \u161?Alabada sea mi Roca! \u161?Que sea enaltecido el Dios de mi salvaci\u243?n! (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=19018046&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lan