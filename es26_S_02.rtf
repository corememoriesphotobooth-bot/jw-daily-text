46015025&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Primera a los Corintios cap\u237?tulo 15 vers\u237?culo 25}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ; }{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=49005023&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Efesios cap\u237?tulo 5 vers\u237?culo 23}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ; }{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=58002017&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Hebreos cap\u237?tulo 2 vers\u237?culo 17}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). Est\u225? a cargo de reunir a los ungidos y a la gran muchedumbre, una labor que quedar\u225? completada antes de que termine la gran tribulaci\u243?n (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=40025032&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Mateo cap\u237?tulo 25 vers\u237?culo 32}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). Tambi\u233?n se asegura de que sus siervos fieles est\u233?n bien alimentados espiritualmente en estos \u250?ltimos d\u237?as (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=40024045&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Mateo cap\u237?tulo 24 vers\u237?culo 45}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). Y, durante su Reinado de Mil A\u241?os, seguir\u225? trabajando para ayudarnos. Como vemos, cuando Jehov\u225? entreg\u243? a su Hijo, no\u160?solo lo hizo para que \u233?l diera su vida, sino tambi\u233?n para que hiciera much\u237?simas otras cosas por nosotros. }{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i La Atalaya, enero de 2025 p\u225?gina }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 2}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 4 }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 p\u225?rrafo}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2  12\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\s3\qc {\rtlch\fcs1\alang1034\af1\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf2\b Martes 3 de febrero\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\ql\fi576 {\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i Es un regalo que por su bondad inmerecida se les est\u233? declarando justos mediante la liberaci\u243?n por el rescate que pag\u243? Cristo Jes\u250?s (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=45003024&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i\ul Romanos cap\u237?tulo 3 vers\u237?culo 24}}}{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i ).\par}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 Cuando Jehov\u225? nos perdona, nuestros pecados desaparecen por completo y para siempre. Esto nos permite tener una buena relaci\u243?n con nuestro Padre celestial. Ahora bien, no\u160?debemos olvidar que el perd\u243?n de Jehov\u225? no\u160?es algo que merezcamos ni\u160?que podamos exigirle. Es un regalo que \u233?l nos hace porque nos ama y porque es muy generoso. \u161?Qu\u233? agradecidos estamos porque, como dice }{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=19130004&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf3\ul Salm}}}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=19130004&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul o cap\u237?tulo 130 vers\u237?culo 4}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 , en Jehov\u225? est\u225? \u8220?el verdadero perd\u243?n\u8221?! (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=45004008&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Romanos cap\u237?tulo 4 vers\u237?culo 8}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). Eso s\u237?, si queremos que Jehov\u225? nos perdone, debemos hacer caso a esta advertencia que dio Jes\u250?s: \u8220?Si no\u160?les perdonan sus ofensas a los dem\u225?s, su Padre tampoco perdonar\u225? las ofensas de ustedes\u8221? (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=40006014-40006015&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Mateo cap\u237?tulo 6 vers\u237?culos 14,}}}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=40006014-40006015&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf3\ul 15}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). As\u237? que es imprescindible que imitemos el perd\u243?n de Jehov\u225?. }{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i La Atalaya, febrero de 2025 p\u225?gina }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 1}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 3 }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 p\u225?rrafos}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2  18,\u160?19\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\s3\qc {\rtlch\fcs1\alang1034\af1\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf2\b Mi\u233?rcoles 4 de febrero\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\ql\fi576 {\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i Va a haber una resurrecci\u243?n tanto de justos como de injustos (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=44024015&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i\ul Hechos cap\u237?tulo 24 vers\u237?culo 15}}}{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i ).\par}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 Pensemos en la gente de Sodoma y Gomorra. Sabemos que en Sodoma viv\u237?a un hombre justo llamado Lot. Pero no\u160?sabemos si les predic\u243? a todos sus habitantes. Es cierto que eran malvados, pero \u191?sab\u237?an todos ellos distinguir entre lo que estaba bien y lo que estaba mal? Parece que no, porque la Biblia dice que una multitud de hombres de Sodoma intentaron abusar sexualmente de los invitados de Lot. Entre esa multitud hab\u237?a gente muy joven que quiz\u225?s no\u160?entend\u237?a la gravedad de sus actos (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=01019004&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul G\u233?nesis cap\u237?tulo 19 vers\u237?culo 4}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ; }{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=61002007&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Segunda de Pedro cap\u237?tulo 2 vers\u237?culo 7}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). \u191?De verdad podemos afirmar con seguridad que Jehov\u225?, que es tan misericordioso, ha decidido que ninguna de esas personas va a resucitar? Es cierto que Jehov\u225? le dio a entender a Abrah\u225?n que en esa ciudad no\u160?hab\u237?a ni\u160?siquiera 10 justos (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=01018032&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul G\u233?nesis cap\u237?tulo 18 vers\u237?culo 32}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). As\u237? que eran injustos y Jehov\u225? actu\u243? con justicia al destruirlos. Ahora bien, \u191?podemos asegurar que ni\u160?uno solo de ellos volver\u225? a la vida en la resurrecci\u243?n de los injustos? No\u160?podemos asegurarlo. }{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i La Atalaya, mayo de 2024 p\u225?gina }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 2}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2  }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 p\u225?rrafo}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2  3; 3 }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 p\u225?rrafo}{\rtlch\fcs1\alang1034\af2\ltrch