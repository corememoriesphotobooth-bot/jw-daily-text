r=lang&bible=48006007-48006008&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf3\ul 8}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). Jehov\u225? no\u160?obliga a nadie a servirle, sino que deja que cada uno decida lo que va a hacer. Ahora bien, \u191?qu\u233? pasa si un cristiano bautizado comete un pecado grave? Si no\u160?se arrepiente, se le debe sacar de la congregaci\u243?n (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=46005013&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Primera a los Corintios cap\u237?tulo 5 vers\u237?culo 13}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). Pero, incluso en ese caso, Jehov\u225? desea de todo coraz\u243?n que vuelva a \u233?l. De hecho, una raz\u243?n importante por la que dio el rescate es para poder perdonar a quienes se arrepienten de sus pecados. Nuestro Dios es tan amoroso que les tiende la mano a los pecadores y los anima a arrepentirse (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=38001003&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Zacar\u237?as cap\u237?tulo 1 vers\u237?culo 3}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ; }{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=45002004&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Romanos cap\u237?tulo 2 vers\u237?culo 4}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ; }{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=59004008&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alan