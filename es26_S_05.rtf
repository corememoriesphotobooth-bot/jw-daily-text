1&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Romanos cap\u237?tulo 13 vers\u237?culo 11}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). Mientras no\u160?llegue el fin, tenemos que seguir predicando. Hay algo muy importante que todos debemos preguntarnos: \u191?por qu\u233? predicamos las buenas noticias? Dicho en pocas palabras, por amor. Cuando predicamos, demostramos que amamos las buenas noticias, que amamos a la gente y sobre todo que amamos a Jehov\u225? y su nombre. }{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i La Atalaya, mayo de 2024 p\u225?gina }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 1}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 4 }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 p\u225?rrafos}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2  2,\u160?3\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\s3\qc {\rtlch\fcs1\alang1034\af1\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf2\b Domingo 17 de mayo\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\ql\fi576 {\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i Dios vio todo lo que hab\u237?a hecho y, \u161?miren!, todo era muy bueno (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=01001031&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i\ul G\u233?nesis cap\u237?tulo 1 vers\u237?culo 31}}}{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i ).\par}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 Padres, animen a sus hijos a fijarse en la naturaleza. Al pasear por el campo o trabajar la tierra, mu\u233?strenles los asombrosos patrones que hay en el mundo natural. Esos patrones indican que alguien inteligente y sabio tuvo que dise\u241?arlos. Por ejemplo, los cient\u237?ficos han estudiado por a\u241?os los patrones en forma de espiral que tienen algunos objetos de la naturaleza. Seg\u250?n explica un biof\u237?sico llamado Nicola Fameli, cuando se cuenta el n\u250?mero de espirales en estos objetos, se descubre cierto patr\u243?n o serie de n\u250?meros, lo que se conoce como }{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i la sucesi\u243?n de Fibonacci. }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 En la naturaleza existen muchos objetos que tienen un patr\u243?n en espiral, como la forma de algunas galaxias, el caparaz\u243?n del nautilo, las hojas de algunas plantas y la cabeza de los girasoles. }{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i La Atalaya, diciembre de 2024 p\u225?gina }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 1}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 6 }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 p\u225?rrafo}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2  7\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\s3\qc {\rtlch\fcs1\alang1034\af1\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf2\b Lunes 18 de mayo\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\ql\fi576 {\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i \u201?l es su vida (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=05030020&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i\ul Deuteronomio cap\u237?tulo 30 vers\u237?culo 20}}}{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i ).\par}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 Mois\u233?s, David y Juan vivieron en \u233?pocas y circunstancias diferentes de las nuestras. Sin embargo, tenemos mucho en com\u250?n con ellos. Ellos serv\u237?an al Dios verdadero, y nosotros tambi\u233?n. Al igual que ellos, nosotros le oramos a Jehov\u225?, confiamos en \u233?l y acudimos a \u233?l en busca de gu\u237?a. Y, como aquellos hombres de la antig\u252?edad, estamos convencidos de que Jehov\u225? bendice generosamente a los que lo obedecen. Por tanto, prestemos atenci\u243?n a las palabras de despedida de estos hombres mayores y obedezcamos los mandamientos de Jehov\u225?. As\u237? tendremos verdadero \u233?xito en todo lo que hagamos. Viviremos \u8220?mucho tiempo\u8221?, s\u237?, para siempre. Y tendremos la alegr\u237?a de agradar a nuestro amoroso Padre celestial, que cumple todas sus promesas. \u161?No podemos ni\u160?imaginar todas las bendiciones que nos tiene preparadas! (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=49003020&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Efesios cap\u237?tulo 3 vers\u237?culo 20}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). }{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i La Atalaya, noviembre de 2024 p\u225?gina }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 1}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 3 }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 p\u225?rrafos}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2  20,\u160?21\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\s3\qc {\rtlch\fcs1\alang1034\af1\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf2\b Martes 19 de mayo\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\ql\fi576 {\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i Dios asign\u243? a las personas en la congregaci\u243?n (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=46012028&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i\ul Primera a los Corintios cap\u237?tulo 12 vers\u237?culo 28}}}{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i ).\par}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 En el siglo primero, a algunos hermanos se les nombraba siervos ministeriales (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=54003008&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Primera a Timoteo cap\u237?tulo 3 vers\u237?culo 8}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). Seg\u250?n parece, ellos eran los que prestaban los \u8220?servicios de ayuda\u8221? de los que habl\u243? el ap\u243?stol Pablo. Por lo visto, atend\u237?an algunas labores necesarias para que los ancianos pudieran concentrarse en ense\u241?ar y pastorear. Por ejemplo, los siervos ministeriales tal vez ayudaban a hacer copias de las Escrituras o a comprar los materiales necesarios para hacer esas copias. \u191?Cu\u225?les son algunas de las tareas que realizan los siervos ministeriales hoy d\u237?a? (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=60004010&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Primera de Pedro cap\u237?tulo 4 vers\u237?culo 10}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). Tal vez se encarguen de la contabilidad de la congregaci\u243?n, de los territorios, de solicitar publicaciones y hac\u233?rselas llegar a los publicadores, de manejar el equipo de audio y video, de servir de acomodadores o de ayudar en el mantenimiento del Sal\u243?n del Reino. Todas estas cosas son necesarias para que la congregaci\u243?n funcione bien (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=46014040&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Primera a los Corintios cap\u237?tulo 14 vers\u237?culo 40}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). }{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i La Atalaya, octubre de 2024 p\u225?gina }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 1}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 9 }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 p\u225?rrafos}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2  4,\u160?5\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\s3\qc {\rtlch\fcs1\alang1034\af1\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf2\b Mi\u233?rcoles 20 de mayo\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\ql\fi576 {\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i Tengo fuerzas para todo gracias a aquel que me da poder (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=50004013&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i\ul Filipenses cap\u237?tulo 4 vers\u237?culo 13}}}{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\i ).\par}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 Podremos aguantar cualquier dificultad por grande que sea si recordamos que Jehov\u225? est\u225? vivo y est\u225? ah\u237? para darnos su apoyo. A fin de cuentas, es el Todopoderoso y nos puede dar las fuerzas para aguantar lo que sea. As\u237? que tenemos sobradas razones para enfrentar las pruebas con confianza. Ver que Jehov\u225? nos ayuda con los problemas m\u225?s peque\u241?os nos convence de que tambi\u233?n nos ayudar\u225? con los m\u225?s grandes. Veamos dos cosas que el rey David vivi\u243? y que lo ayudaron a confiar m\u225?s en Jehov\u225?. Cuando era un joven pastor, vino un le\u243?n y se llev\u243? una oveja del reba\u241?o de su padre, y en otra ocasi\u243?n vino un oso e hizo lo mismo. En los dos casos, David los persigui\u243? con valor y salv\u243? a las ovejas. Sab\u237?a que Jehov\u225? le hab\u237?a dado las fuerzas para hacerlo y por eso no\u160?intent\u243? llevarse el m\u233?rito (}{\field{\*\fldinst {HYPERLINK "https://www.jw.org/finder?wtlocale=S&prefer=lang&bible=09017034-09017037&pub=nwtsty" }}{\fldrslt{\cs5\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\ul Primero de Samuel cap\u237?tulo 17 vers\u237?culos 34 a 37}}}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 ). David medit\u243? en aquellas vivencias y as\u237? se convenci\u243? a\u250?n m\u225?s de que el Dios vivo lo fortalecer\u237?a en el futuro. }{\rtlch\fcs1\alang1034\af2\ai\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4\i La Atalaya, junio de 2024 p\u225?gina }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2\cf4 2}{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp1034\langfe1034\langfenp1034\f2 1 }{\rtlch\fcs1\alang1034\af2\ltrch\fcs0\lang1034\langnp10